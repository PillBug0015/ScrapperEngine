{
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/header",
                "${workspaceFolder}/source",
                "${workspaceFolder}/**"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/clang++",
            "compilerArgs": [
                "-I${workspaceFolder}/header"
