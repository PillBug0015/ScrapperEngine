{
    "version": 3,
    "configurePresets": [
        {
            "name": "MacOS",
            "displayName": "MacOS",
            "binaryDir": "${sourceDir}/build/MacOS",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "Windows",
            "displayName": "Windows",
            "binaryDir": "${sourceDir}/build/Windows",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "MacOS",
            "configurePreset": "MacOS",
            "configuration": "Debug"
        },
        {
            "name": "Windows",
            "configurePreset": "Windows",
            "configuration": "Debug"
        }
    ]
}
